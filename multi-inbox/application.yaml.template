---
spring:
  datasource:
    url: "$DB_URL"
    username: "$DB_USER"
    password: "$DB_PASSWORD"
  ai:
    anthropic:
      api-key: "$ANTHROPIC_API_KEY"
app:
  base-url: "$APP_BASE_URL"
proxy:
  host: "$PROXY_HOST"
  port: $PROXY_PORT
  user: "$PROXY_USER"
  pass: "$PROXY_PASS"
  connection-timeout: 20000
